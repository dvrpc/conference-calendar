{
  "name": "conference-calendar-admin",
  "image": "mcr.microsoft.com/devcontainers/base:trixie",
  "runArgs": ["--name", "conference-calendar-admin"],
  "features": {
    "ghcr.io/devcontainers/features/node:2": {
      "version": "24"
    }
  },
  "postCreateCommand": "cd /workspaces/conference-calendar-admin && npm ci --legacy-peer-deps",
  "customizations": {
    "vscode": {
      "extensions": ["oxc.oxc-vscode", "bradlc.vscode-tailwindcss"],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "oxc.lint.enable": true,
        "oxc.lint.run": "onSave",
        "oxc.typeAware": true,
        "oxc.path.oxfmt": "./node_modules/.bin/oxfmt",
        "oxc.path.oxlint": "./node_modules/.bin/oxlint"
      }
    }
  }
}
